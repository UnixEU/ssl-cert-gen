HOSTNAME=custom-server
TLS_COUNTRY=US
TLS_STATE=New York
TLS_CITY=Albany
TLS_ORG=IT Company
TLS_OU=IT
TLS_DAYS=3650

# Additional Subject Alternative Names (comma-separated, no spaces).
# The HOSTNAME above is included automatically as DNS:${HOSTNAME}.
# Add any additional IPs or DNS names that clients will use to connect.
# Bare hostnames are treated as DNS entries automatically.
# Example: DNS:custom-server.internal,custom-server.local,IP:10.0.0.5
TLS_EXTRA_SANS=
